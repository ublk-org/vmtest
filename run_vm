#!/bin/bash
# SPDX-License-Identifier: GPL-2.0
#
# Boot the configured kernel under virtme-ng and run a test script inside.
#
# Usage (low-level):
#   ./run_vm <test-script-inside-vm> [args...]
#
# You normally invoke this via `./vmtest run <name>` instead.
#
# Requires KERNEL_DIR (from vmtest.conf or env) to point at a built kernel
# tree. The test script path is resolved on the host; the host fs is
# visible inside the VM via 9p so any absolute path under the repo works.
set -eu

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
. "$SELF_DIR/lib/common.sh"
vt_load_config

# `--shell` drops into an interactive root shell inside the guest instead
# of running a test. This must NOT go through virtme-ng's --exec/--script-sh
# path: in script mode the kernel console is a write-only chardev and the
# script's stdin is a non-tty virtio-serial port, so an interactive shell
# there gets no input and no job control. Interactive mode (no --exec) wires
# a bidirectional getty on the serial console instead. We reintroduce the
# env that --exec would have forwarded via a generated --shell wrapper below.
SHELL_MODE=
if [ "${1:-}" = "--shell" ]; then
	SHELL_MODE=1; shift
	TEST_CMD=
else
	if [ $# -lt 1 ]; then
		echo "usage: $0 <test-script|--shell> [args...]" >&2
		exit 2
	fi
	TEST_CMD="$1"; shift
fi

# Sanity checks before we shell out to vng.
VNG_BIN="${VMTEST_VNG:-vng}"
command -v "$VNG_BIN" >/dev/null \
	|| vt_die "'$VNG_BIN' not found (install virtme-ng or set VMTEST_VNG)"
[ -d "$KERNEL_DIR" ] \
	|| vt_die "KERNEL_DIR=$KERNEL_DIR does not exist (set it in vmtest.conf)"
[ -f "$KERNEL_DIR/vmlinux" ] \
	|| vt_die "no vmlinux in $KERNEL_DIR — build the kernel first"

# Lazily create the two extra block devices the IOMMU tests want.
SDISK="$VMTEST_DATA_DIR/d1.img"
NDISK="$VMTEST_DATA_DIR/d2.img"
SDISK_SIZE="${VMTEST_SDISK_SIZE:-2G}"
NDISK_SIZE="${VMTEST_NDISK_SIZE:-2G}"
[ -f "$SDISK" ] || { vt_log "creating $SDISK ($SDISK_SIZE)"; truncate -s "$SDISK_SIZE" "$SDISK"; }
[ -f "$NDISK" ] || { vt_log "creating $NDISK ($NDISK_SIZE)"; truncate -s "$NDISK_SIZE" "$NDISK"; }

QEMU_EXTRA="-machine q35,kernel-irqchip=split \
  -device intel-iommu,intremap=on,caching-mode=on,device-iotlb=on \
  -device virtio-scsi-pci,id=scsi_extra,num_queues=32 \
  -device scsi-hd,drive=extra_hd,bus=scsi_extra.0 \
  -drive if=none,id=extra_hd,file=${SDISK},format=raw \
  -drive file=${NDISK},format=raw,if=none,id=nvme_drv \
  -device nvme,drive=nvme_drv,serial=12345${VMTEST_QEMU_EXTRA:+ $VMTEST_QEMU_EXTRA}"

KCMDLINE="intel_iommu=on systemd.mask=dev-zram0.device systemd.mask=systemd-zram-setup@zram0.service${VMTEST_KCMDLINE_EXTRA:+ $VMTEST_KCMDLINE_EXTRA}"

export TMPDIR="$VMTEST_TMPDIR"

# Forward config the test scripts may want.
GUEST_ENV="VMTEST_DATA_DIR=$VMTEST_DATA_DIR"
[ -n "${UBLKSRV_DIR:-}" ] && GUEST_ENV="$GUEST_ENV UBLKSRV_DIR=$UBLKSRV_DIR"
[ -n "${FIO_DIR:-}"     ] && GUEST_ENV="$GUEST_ENV FIO_DIR=$FIO_DIR"
[ -n "${RUBLK_DIR:-}"   ] && GUEST_ENV="$GUEST_ENV RUBLK_DIR=$RUBLK_DIR"
[ -n "${LIBURING_DIR:-}" ] && GUEST_ENV="$GUEST_ENV LIBURING_DIR=$LIBURING_DIR"
# Honoured by tests that want to hold the VM open after the test body
# completes (e.g., for post-mortem inspection via ssh). Tests should
# `sleep infinity` (or similar) when this is set.
[ -n "${VMTEST_HOLD:-}" ] && GUEST_ENV="$GUEST_ENV VMTEST_HOLD=$VMTEST_HOLD"
# In interactive shell mode, carry the host TERM through so readline,
# clear, and full-screen tools (vim, less) behave inside the guest.
if [ -n "$SHELL_MODE" ]; then
	GUEST_ENV="$GUEST_ENV TERM=${TERM:-xterm}"
	vt_log "shell mode: dropping into an interactive root shell in the guest"
	vt_log "  exit the shell (or Ctrl-D) to power off the VM"
fi

# Optional: enable networking + in-VM sshd so a user can `vng --ssh-client`
# (or plain `ssh root@localhost -p <port>`) into the running VM. Off by
# default to keep test boots fast and hermetic. Set VMTEST_SSH=1 to opt in.
NET_ARGS=()
if [ -n "${VMTEST_SSH:-}" ]; then
	NET_ARGS+=(--network user --ssh --ssh-tcp)
	vt_log "VMTEST_SSH=1: enabling user-mode networking + in-VM sshd"
	vt_log "  attach with: $VNG_BIN --ssh-client --ssh-tcp"
	vt_log "  (run from another terminal; --ssh-tcp must match on both sides)"
fi

# Build a guest PATH that includes any cargo-installed bin dirs present
# on the host. /home is exposed read-write into the guest via overlay,
# so paths like /home/<user>/.cargo/bin resolve at the same absolute
# location inside the VM. The glob expands here (on the host) before
# vng is invoked; missing directories are filtered out.
GUEST_PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
for d in /home/*/.cargo/bin /root/.cargo/bin; do
	[ -d "$d" ] && GUEST_PATH="$d:$GUEST_PATH"
done

# Mode-specific vng args. Test mode runs the script via --exec, prefixing
# the env that vng does not otherwise forward. Shell mode instead boots
# interactively (so the getty owns the console for bidirectional I/O) and
# carries the same env through a generated wrapper passed to --shell. The
# wrapper lives under VMTEST_TMPDIR, which is mounted into the guest at the
# same absolute path, so vng can exec it as the login shell.
MODE_ARGS=()
if [ -n "$SHELL_MODE" ]; then
	SHELL_WRAPPER="$VMTEST_TMPDIR/vmtest-shell.sh"
	{
		echo '#!/bin/bash'
		# printf %q shell-quotes each value so quotes/spaces/metacharacters
		# in a forwarded path can't break or inject into the wrapper.
		printf 'export PATH=%q\n' "$GUEST_PATH"
		for kv in $GUEST_ENV; do
			printf 'export %s=%q\n' "${kv%%=*}" "${kv#*=}"
		done
		printf 'cd %q 2>/dev/null || true\n' "$SELF_DIR"
		echo 'exec bash -i'
	} > "$SHELL_WRAPPER"
	chmod +x "$SHELL_WRAPPER"
	MODE_ARGS=(--shell "$SHELL_WRAPPER")
else
	MODE_ARGS=(--exec "env PATH=$GUEST_PATH $GUEST_ENV $TEST_CMD $*")
fi

# shellcheck disable=SC2086
"$VNG_BIN" --run "$KERNEL_DIR" --force-9p \
	--cpus "${VMTEST_CPUS:-16}" --memory "${VMTEST_MEM:-8G}" \
	--verbose \
	--rwdir "$VMTEST_DATA_DIR" \
	--user root \
	"${NET_ARGS[@]}" \
	--append "$KCMDLINE" \
	"${MODE_ARGS[@]}" \
	"--qemu-opts=$QEMU_EXTRA"
