# vmtest configuration — copy to vmtest.conf and edit.
#
# Any of these can also be set in the environment; the environment wins.
# Paths may use ~ and shell expansions (the file is sourced by bash).

# --- Required ---------------------------------------------------------

# Kernel source tree to boot. Must already be built (vmlinux + modules).
# If unset, vmtest assumes the repo lives at <kernel>/vmtest/ and uses
# its parent directory.
#KERNEL_DIR="$HOME/git/linux"

# --- Optional ---------------------------------------------------------

# Where vmtest stores disk images, hugetlb buffers, scratch files.
# Exposed to the VM read-write via 9p.
#VMTEST_DATA_DIR="$(dirname "$BASH_SOURCE")/data"

# Out-of-tree ublksrv build (needed by ublksrv_* and nvme_vfio_* tests).
# vmtest looks for $UBLKSRV_DIR/.libs/ublk and the .so files under lib/.libs.
#UBLKSRV_DIR="$HOME/git/ublksrv"

# fio source tree (needed by t_io_uring_* tests that use fio/t/io_uring).
# Plain `fio` from $PATH is enough for the other fio-based tests.
#FIO_DIR="$HOME/git/fio"

# liburing source tree (needed by the liburing_* tests, which run the
# prebuilt test binaries under $LIBURING_DIR/test).
#LIBURING_DIR="$HOME/git/others/liburing"

# Rust ublk crate to run `cargo test` against.
#RUBLK_DIR="$VMTEST_DATA_DIR/rublk"

# --- VM tuning --------------------------------------------------------

# CPUs / memory passed to vng.
#VMTEST_CPUS=16
#VMTEST_MEM=8G

# Extra kernel command-line args appended to the default.
#VMTEST_KCMDLINE_EXTRA=""

# Path to the vng binary (default: looked up via $PATH).
#VMTEST_VNG="/opt/virtme-ng/bin/vng"

# Extra QEMU args appended after our IOMMU + extra-disks block.
# Useful for attaching a passthrough device, extra NIC, etc.
#VMTEST_QEMU_EXTRA="-device virtio-net-pci,netdev=n0 -netdev user,id=n0"

# Sizes of the auto-created scratch disks (used on first boot only).
#VMTEST_SDISK_SIZE="2G"
#VMTEST_NDISK_SIZE="2G"

# --- Investigation aids -----------------------------------------------
# These are typically set per-invocation on the command line rather than
# in the config file, but they're documented here for discoverability.
#
# VMTEST_NET     User-mode networking, ON BY DEFAULT. The guest gets a DHCP
#                address and reaches host services at the gateway 10.0.2.2 (a
#                server bound on the host's 127.0.0.1:PORT is 10.0.2.2:PORT in
#                the guest). Useful as: host runs the server, guest is client.
#                Set VMTEST_NET=0 to disable for a hermetic boot.
# VMTEST_SSH=1   Enable an in-VM sshd (forces networking on even if NET=0).
#                Connect from another terminal with:  vng --ssh-client --ssh-tcp
# VMTEST_HOLD=1  Have the test script call `vt_hold` (sleep infinity)
#                after its body completes -- the VM stays up instead of
#                powering off, so you can ssh in and inspect kernel state.
#                Combine the two for live post-mortem:
#                  VMTEST_SSH=1 VMTEST_HOLD=1 ./vmtest run <name>
